generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum UserRole {
  MEMBER
  REVIEWER
  ORGANIZER
  SUPER_ADMIN
}

enum ProfileCompletionStatus {
  INCOMPLETE
  COMPLETE
}

enum EventStatus {
  UPCOMING
  LIVE
  CLOSED
  ARCHIVED
}

enum RSVPStatus {
  GOING
  CANCELED
}

enum AttendanceMethod {
  QR_SCAN
  MANUAL
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  IN_CONSIDERATION
  ACCEPTED
  REJECTED
  WAITLISTED
  COMPLETED
  ARCHIVED
}

enum ProgramType {
  AI_ACADEMY
  AI_INNOVATION
  AI_MENTORSHIP_MENTOR
  AI_MENTORSHIP_MENTEE
}

enum MembershipType {
  NON_MEMBER
  AI_STUDENT
  AIM_MENTOR
  AIM_MENTEE
  AI_INNOVATOR
  ALUMNUS
}

// -----------------------------------------------------------------------------
// MODELS
// -----------------------------------------------------------------------------

model User {
  id      String   @id @default(cuid())
  clerkId String   @unique
  email   String   @unique
  role    UserRole @default(MEMBER)

  verifiedAt  DateTime?
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile     Profile?
  memberships Membership[]
  rsvps       RSVP[]
  attendance  Attendance[]
  submissions ApplicationSubmission[]
  drafts      ApplicationDraft[]
  reviews     ApplicationReview[]

  // Relations mapped from other models
  uploadedFiles   File[]
  createdEvents   Event[]
  createdApps     ProgramApplication[]
  checkedInEvents Attendance[]         @relation("AttendanceChecker")
  auditLogs       AuditLog[]           @relation("AuditActor")
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  firstName    String
  lastName     String
  middleName   String
  prefName     String
  year         String
  degree       String
  major        String
  utdEmail     String?
  utdNetId     String?
  githubUrl    String?
  linkedinUrl  String?
  portfolioUrl String?

  profileCompletionStatus ProfileCompletionStatus

  resumeFileId String?
  resumeFile   File?   @relation(fields: [resumeFileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model File {
  id           String   @id @default(cuid())
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  fileName     String
  mimeType     String
  fileSize     Int
  storageKey   String
  createdAt    DateTime @default(now())

  resumes Profile[]
  pdfs    ApplicationSubmission[]
}

model Event {
  id               String      @id @default(cuid())
  title            String
  description      String      @db.Text
  location         String
  startTime        DateTime
  endTime          DateTime
  status           EventStatus
  capacity         Int?
  visibility       String?
  eligibilityRules Json?
  createdById      String
  createdBy        User        @relation(fields: [createdById], references: [id])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  rsvps      RSVP[]
  attendance Attendance[]
}

model RSVP {
  id          String     @id @default(cuid())
  userId      String
  eventId     String
  status      RSVPStatus
  qrToken     String
  qrExpiresAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  event Event @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Attendance {
  id            String           @id @default(cuid())
  userId        String
  eventId       String
  checkedInById String?
  checkedInAt   DateTime         @default(now())
  method        AttendanceMethod

  user        User  @relation(fields: [userId], references: [id])
  event       Event @relation(fields: [eventId], references: [id])
  checkedInBy User? @relation("AttendanceChecker", fields: [checkedInById], references: [id])

  @@unique([userId, eventId])
}

model ProgramApplication {
  id             String      @id @default(cuid())
  title          String
  description    String      @db.Text
  programType    ProgramType
  openAt         DateTime
  closeAt        DateTime
  decisionDate   DateTime?
  visibleToUsers Boolean     @default(true)
  retentionUntil DateTime?
  createdById    String
  createdBy      User        @relation(fields: [createdById], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  submissions ApplicationSubmission[]
  drafts      ApplicationDraft[]
}

model ApplicationDraft {
  id              String   @id @default(cuid())
  applicationId   String
  userId          String
  formPayloadJson Json
  stepIndex       Int
  isSubmitted     Boolean  @default(false)
  lastSavedAt     DateTime @updatedAt

  application ProgramApplication @relation(fields: [applicationId], references: [id])
  user        User               @relation(fields: [userId], references: [id])

  @@unique([applicationId, userId])
}

model ApplicationSubmission {
  id              String            @id @default(cuid())
  applicationId   String
  userId          String
  versionNumber   Int
  formPayloadJson Json
  pdfFileId       String?
  pdfFile         File?             @relation(fields: [pdfFileId], references: [id])
  status          ApplicationStatus
  submittedAt     DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  application ProgramApplication  @relation(fields: [applicationId], references: [id])
  user        User                @relation(fields: [userId], references: [id])
  reviews     ApplicationReview[]
}

model ApplicationReview {
  id            String            @id @default(cuid())
  submissionId  String
  reviewerId    String
  status        ApplicationStatus
  notesInternal String?           @db.Text
  updatedAt     DateTime          @updatedAt

  submission ApplicationSubmission @relation(fields: [submissionId], references: [id])
  reviewer   User                  @relation(fields: [reviewerId], references: [id])
}

model Membership {
  id                  String         @id @default(cuid())
  userId              String
  membershipType      MembershipType
  startDate           DateTime
  endDate             DateTime?
  activeFlag          Boolean        @default(false)
  sourceApplicationId String?
  createdAt           DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  actionType   String
  entityType   String
  entityId     String
  metadataJson Json?
  createdAt    DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id])
}
